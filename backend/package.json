{
  "name": "mitaneko-backend",
  "version": "1.0.0",
  "description": "Backend API pour MITANEKO - Plateforme de Gouvernance Participative Urbaine",
  "main": "src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js"
  },
  "keywords": [
    "civic-tech",
    "governance",
    "participative",
    "madagascar",
    "urban"
  ],
  "author": "MITANEKO Team",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "pg": "^8.8.0",
    "pg-promise": "^11.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "joi": "^17.9.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.32.0",
    "firebase-admin": "^11.8.0",
    "redis": "^4.6.5",
    "axios": "^1.3.4",
    "uuid": "^9.0.0",
    "express-async-errors": "^3.1.1",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.15.11",
    "@types/pg": "^8.9.0",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/multer": "^1.4.7",
    "typescript": "^5.0.2",
    "ts-node": "^10.9.1",
    "nodemon": "^2.0.20",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.1",
    "ts-jest": "^29.1.0",
    "eslint": "^8.38.0",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1"
  }
