# MITANEKO AI Backend - Configuration
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Backend API principale (MITANEKO)
MITANEKO_API_URL=http://localhost:5000/api
MITANEKO_API_KEY=changeme

# Base de données (lecture analytics)
DATABASE_URL=postgresql://mitaneko:mitaneko@localhost:5432/mitaneko

# JWT (doit correspondre au backend principal)
JWT_SECRET=mitaneko_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256

# Redis (cache, rate limiting)
REDIS_URL=redis://localhost:6379/0

# Hugging Face (optionnel, fallback modèles locaux)
HF_TOKEN=

# Google Gemini (optionnel, pour chatbot)
GEMINI_API_KEY=

# OpenAI (optionnel, fallback)
OPENAI_API_KEY=

# OpenRouter (LLM pour le chatbot intelligent)
OPENROUTER_API_KEY=changeme
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Modèles par défaut
CLASSIFIER_MODEL=mitaneko_classifier.pkl
SENTIMENT_MODEL=nicolas56/french-sentiment-analysis
TRANSLATION_MODEL=Helsinki-NLP/opus-mt-fr-mg
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
VISION_MODEL=google/vit-base-patch16-224
